# PyInstaller のビルド生成物（.exe関連）を除外
build/
dist/
*.spec

# Python の仮想環境を除外
# フォルダ名が venv や .venv の場合を想定しています
venv/
.venv/
ENV/

# Python のキャッシュファイルを除外
__pycache__/
*.pyc

# ログファイルや一時ファイル
*.log

# 起動用bat
run.bat

# ==========================
# Gemini 関連
# ==========================
.gemini/
.gemini
GEMINI.md

# ==========================
# Claude 関連
# ==========================
.claude/
.claude
.claudeignore

# ==========================
# その他 AI エージェント関連
# ==========================
.agents/
.agent/
_agents/
_agent/